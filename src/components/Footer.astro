---
import SocialLinks from "./home/SocialLinks";
import { socialLinks } from "../data/about";

const currentYear = new Date().getFullYear();

const FOOTER_LINKS = [
    { href: "/about", label: "關於我們" },
    { href: "/announce", label: "公告" },
    { href: "/announce#journal", label: "活動日誌" },
    { href: "/calendar", label: "行事曆" },
    { href: "/groups", label: "小組" },
    { href: "/special-thanks", label: "幹部" },
    { href: "/links", label: "相關連結" },
    { href: "/links#convenient", label: "便利連結" },
    { href: "/links#tools", label: "自製小工具" },
    { href: "/links#friends", label: "友情社團" },
];
---

<footer class="border-t border-gray-800 bg-gray-900">
    <div class="mx-auto max-w-6xl px-6 py-10">
        <div class="grid gap-8 sm:grid-cols-3">
            <div>
                <a href="/" class="flex items-center gap-2">
                    <img
                        src="/logo.webp"
                        alt="社團 Logo"
                        class="h-9 w-9 object-contain"
                    />
                    <span class="font-semibold text-white">日本文化研究社</span>
                </a>
                <p class="mt-3 text-sm leading-relaxed text-gray-400">
                    國立陽明交通大學日本文化研究社，致力於推廣日本流行文化、傳統文化與語言交流。
                </p>
            </div>

            <div>
                <h3
                    class="text-sm font-semibold uppercase tracking-widest text-gray-500"
                >
                    快速連結
                </h3>
                <ul class="mt-4 flex flex-wrap gap-x-4 gap-y-2">
                    {
                        FOOTER_LINKS.map((link) => (
                            <li>
                                <a
                                    href={link.href}
                                    class="text-sm text-gray-300 transition-colors hover:text-white"
                                >
                                    {link.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>

            <div>
                <h3
                    class="text-sm font-semibold uppercase tracking-widest text-gray-500"
                >
                    聯絡我們
                </h3>
                <p class="mt-4 text-sm text-gray-300">
                    nycu.seiyuu.club@gmail.com
                </p>
                <div class="mt-8">
                    <SocialLinks
                        client:load
                        links={socialLinks}
                        variant="dark"
                    />
                </div>
            </div>
        </div>

        <div
            class="mt-8 border-t border-gray-800 pt-5 text-center text-sm text-gray-500"
        >
            ©{currentYear} 交大日本文化研究社
        </div>
    </div>
</footer>
