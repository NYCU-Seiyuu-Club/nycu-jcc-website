---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnnounceList from '../components/announce/AnnounceList';
import JournalList from '../components/announce/JournalList';
import { announcements } from '../data/announcements';
import { journalEntries } from '../data/journal';
---

<BaseLayout title="公告 | 日本文化研究社" description="查看國立陽明交通大學日本文化研究社的最新公告與活動日誌。">
	<main class="bg-gradient-to-b from-orange-50/60 to-transparent px-6 pt-24 pb-20">
		<section id="announcements" class="reveal mx-auto max-w-6xl scroll-mt-28">
			<AnnounceList client:load announcements={announcements} />
		</section>

		<hr class="mx-auto mt-24 max-w-6xl border-gray-200" />

		<section id="journal" class="reveal mx-auto mt-16 max-w-6xl scroll-mt-28">
			<JournalList client:load entries={journalEntries} />
		</section>
	</main>
</BaseLayout>
