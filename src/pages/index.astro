---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero';

const quickLinks = [
  { href: '/members', label: 'Members', description: '認識社團成員' },
  { href: '/about', label: 'About', description: '社團介紹與宗旨' },
  { href: '/blog', label: 'Blog', description: '活動紀錄與心得分享' },
  { href: '/announce', label: 'Announce', description: '最新公告與消息' },
];
---

<BaseLayout navVariant="overlay">
	<Hero client:load clubName="國立陽明交通大學 日本文化研究社" />

	<main id="main-content" class="mx-auto max-w-6xl px-6 py-20">
		<section class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
			{quickLinks.map((link) => (
				<a
					href={link.href}
					class="rounded-xl border border-gray-200 p-6 transition-shadow hover:shadow-md"
				>
					<h2 class="text-lg font-semibold text-gray-900">{link.label}</h2>
					<p class="mt-2 text-sm text-gray-500">{link.description}</p>
				</a>
			))}
		</section>
	</main>
</BaseLayout>
