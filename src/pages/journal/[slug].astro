---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { journalEntries } from '../../data/journal';
import { getGroupAccentColor } from '../../data/about';

export function getStaticPaths() {
	return journalEntries.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const paragraphs = entry.content.split('\n\n');
---

<BaseLayout
	title={`${entry.title} | 活動日誌`}
	description={entry.summary}
	image={entry.coverImage}
>
	<main class="mx-auto max-w-3xl px-6 pt-28 pb-20">
		<a href="/announce#journal" class="text-sm font-medium text-gray-500 transition-colors hover:text-gray-900">
			← 返回活動日誌
		</a>

		<div class="mt-4 flex items-center gap-3 text-sm text-gray-400">
			<span>{entry.date}</span>
			<span class="rounded-full bg-gray-100 px-3 py-1 font-medium text-gray-500">
				{entry.category}
			</span>
			{entry.group && (
				<span
					class="rounded-full px-3 py-1 font-medium"
					style={`background-color: ${getGroupAccentColor(entry.group)}1a; color: ${getGroupAccentColor(entry.group)}`}
				>
					{entry.group}
				</span>
			)}
		</div>

		<h1 class="mt-3 text-3xl font-bold text-gray-900 sm:text-4xl">{entry.title}</h1>

		<img
			src={entry.coverImage}
			alt={entry.title}
			class="mt-8 aspect-video w-full rounded-2xl object-cover"
		/>

		<div class="mt-8 space-y-4 text-lg leading-relaxed text-gray-700">
			{paragraphs.map((paragraph) => (
				<p>{paragraph}</p>
			))}
		</div>
	</main>
</BaseLayout>
