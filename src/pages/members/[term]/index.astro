---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import MembersBrowser from '../../../components/MembersBrowser';
import { memberTerms } from '../../../data/members';

export function getStaticPaths() {
  return memberTerms.map((term) => ({
    params: { term: term.id },
  }));
}

const { term } = Astro.params;
---

<BaseLayout title="Special Thanks | 日本文化研究社">
	<main class="mx-auto max-w-[96em] px-6 pt-28 pb-20">
		<h1 class="text-3xl font-bold text-gray-900">Special Thanks</h1>
		<p class="mt-2 sm:ml-4 text-gray-500">歷屆幹部介紹</p>

		<div class="mt-4 sm:-mt-3">
			<MembersBrowser client:load terms={memberTerms} initialTermId={term} />
		</div>
	</main>
</BaseLayout>
