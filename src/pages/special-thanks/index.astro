---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HonorMembersBrowser from '../../components/special-thanks/HonorMembersBrowser';
import { honorMemberTerms } from '../../data/honor_members';
---

<BaseLayout
	title="幹部 | 日本文化研究社"
	description="國立陽明交通大學日本文化研究社歷屆幹部介紹。"
>
	<main class="bg-gradient-to-b from-orange-50/60 to-transparent px-6 pt-24 pb-20">
		<div class="reveal mx-auto max-w-6xl">
		<h1 class="text-3xl font-bold text-gray-900">Special Thanks</h1>
		<p class="mt-2 text-gray-500">歷屆幹部介紹</p>
		</div>

		<div class="relative left-1/2 mt-4 w-screen -translate-x-1/2 sm:-mt-3">
			<div class="mx-auto max-w-[96em] px-6">
				<HonorMembersBrowser client:load terms={honorMemberTerms} />
			</div>
		</div>
	</main>
</BaseLayout>
