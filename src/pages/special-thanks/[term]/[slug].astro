---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import HonorMembersBrowser from "../../../components/HonorMembersBrowser";
import { honorMemberTerms } from "../../../data/honor_members";

export function getStaticPaths() {
    return honorMemberTerms.flatMap((term) =>
        term.members.map((member) => ({
            params: { term: term.id, slug: member.slug },
        })),
    );
}

const { term, slug } = Astro.params;
---

<BaseLayout title="Special Thanks | 日本文化研究社">
    <main class="mx-auto max-w-[120em] px-6 pt-24 pb-20">
        <div class="sm:ml-60">
            <h1 class="text-3xl font-bold text-gray-900">Special Thanks</h1>
            <p class="mt-2 sm:ml-2 text-gray-500">特此感謝歷屆幹部參與付出</p>
        </div>

        <div class="mt-4 sm:-mt-3">
            <HonorMembersBrowser
                client:load
                terms={honorMemberTerms}
                initialTermId={term}
                initialSlug={slug}
            />
        </div>
    </main>
</BaseLayout>
