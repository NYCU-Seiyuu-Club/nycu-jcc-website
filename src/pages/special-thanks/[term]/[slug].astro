---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import HonorMembersBrowser from "../../../components/special-thanks/HonorMembersBrowser";
import { findHonorMember, honorMemberTerms } from "../../../data/honor_members";

export function getStaticPaths() {
    return honorMemberTerms.flatMap((term) =>
        term.members.map((member) => ({
            params: { term: term.id, slug: member.slug },
        })),
    );
}

const { term, slug } = Astro.params;
const member = findHonorMember(term, slug);
---

<BaseLayout
    title={`${member?.name ?? ''} | 特別感謝 | 日本文化研究社`}
    description={member?.description ?? '國立陽明交通大學日本文化研究社歷屆幹部介紹。'}
    image={member?.photo}
>
    <main class="bg-gradient-to-b from-orange-50/60 to-transparent px-6 pt-24 pb-20">
        <div class="reveal mx-auto max-w-6xl">
            <h1 class="text-3xl font-bold text-gray-900">Special Thanks</h1>
            <p class="mt-2 text-gray-500">歷屆幹部介紹</p>
        </div>

        <div class="relative left-1/2 mt-4 w-screen -translate-x-1/2 sm:-mt-3">
            <div class="mx-auto max-w-[96em] px-6">
                <HonorMembersBrowser
                    client:load
                    terms={honorMemberTerms}
                    initialTermId={term}
                    initialSlug={slug}
                />
            </div>
        </div>
    </main>
</BaseLayout>
