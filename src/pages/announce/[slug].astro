---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { announcements } from '../../data/announcements';
import { getGroupAccentColor } from '../../data/about';

export function getStaticPaths() {
	return announcements.map((announcement) => ({
		params: { slug: announcement.slug },
		props: { announcement },
	}));
}

const { announcement } = Astro.props;
const paragraphs = announcement.content.split('\n\n');
---

<BaseLayout
	title={`${announcement.title} | 公告`}
	description={announcement.summary}
	image={announcement.coverImage}
>
	<main class="mx-auto max-w-3xl px-6 pt-28 pb-20">
		<a href="/announce" class="text-sm font-medium text-gray-500 transition-colors hover:text-gray-900">
			← 返回公告列表
		</a>

		<div class="mt-4 flex items-center gap-3 text-sm text-gray-400">
			<span>{announcement.date}</span>
			<span class="rounded-full bg-gray-100 px-3 py-1 font-medium text-gray-500">
				{announcement.category}
			</span>
			{announcement.group && (
				<span
					class="rounded-full px-3 py-1 font-medium"
					style={`background-color: ${getGroupAccentColor(announcement.group)}1a; color: ${getGroupAccentColor(announcement.group)}`}
				>
					{announcement.group}
				</span>
			)}
		</div>

		<h1 class="mt-3 text-3xl font-bold text-gray-900 sm:text-4xl">{announcement.title}</h1>

		<img
			src={announcement.coverImage}
			alt={announcement.title}
			class="mt-8 aspect-video w-full rounded-2xl object-cover"
		/>

		<div class="mt-8 space-y-4 text-lg leading-relaxed text-gray-700">
			{paragraphs.map((paragraph) => (
				<p>{paragraph}</p>
			))}
		</div>
	</main>
</BaseLayout>
