---
import BaseLayout from "../layouts/BaseLayout.astro";
import AboutPoem from "../components/home/AboutPoem";
import { aboutIntro, aboutPoems, aboutFaqs } from "../data/about";
---

<BaseLayout title="About | 日本文化研究社">
    <main class="mx-auto max-w-6xl px-6 pt-24 pb-20">
        <div class="reveal mt-16 text-center">
            <h1
                class="inline-block bg-gradient-to-r from-pink-500 via-fuchsia-500 to-cyan-400 bg-clip-text text-3xl font-bold text-transparent"
            >
                國立陽明交通大學日本文化研究社 とは？
            </h1>
        </div>

        <p
            class="reveal mx-auto mt-10 max-w-3xl text-center text-[1.4rem] font-bold leading-relaxed text-gray-700"
        >
            {
                aboutIntro.split("\n").map((line, i) => (
                    <>
                        {i > 0 && <br />}
                        {line}
                    </>
                ))
            }
        </p>

        <section class="reveal mx-auto my-30 max-w-3xl">
            <h2 class="text-center text-3xl font-bold text-gray-900">
                常見問題
            </h2>

            <div class="mt-10 space-y-10">
                {
                    aboutFaqs.map((faq) => (
                        <div>
                            <h3 class="inline bg-gradient-to-r from-pink-500 via-fuchsia-500 to-cyan-400 bg-[length:100%_4px] bg-bottom bg-no-repeat pb-2 text-2xl font-bold leading-loose text-gray-900">
                                Q. {faq.question}
                            </h3>
                            <p class="mt-5 text-lg leading-relaxed text-gray-600">
                                A. {faq.answer}
                            </p>
                        </div>
                    ))
                }
            </div>
        </section>

        <div class="reveal">
            <AboutPoem client:load poems={aboutPoems} />
        </div>
    </main>
</BaseLayout>
