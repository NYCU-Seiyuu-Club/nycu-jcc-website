---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="部落格 | 日本文化研究社">
	<main class="reveal mx-auto flex min-h-[60vh] max-w-3xl flex-col items-center justify-center px-6 pt-28 pb-20 text-center">
		<div
			class="flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br from-pink-100 via-fuchsia-100 to-cyan-100"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				class="h-9 w-9 text-fuchsia-500"
			>
				<path d="M12 20h9" />
				<path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4Z" />
			</svg>
		</div>

		<h1 class="mt-6 text-3xl font-bold text-gray-900">部落格</h1>
		<div class="mt-3 h-1 w-14 rounded-full bg-gradient-to-r from-pink-500 via-fuchsia-500 to-cyan-400" />

		<p class="mt-5 max-w-md text-gray-500">
			我們正在整理社課紀錄、活動花絮與交換心得，部落格內容即將上線，敬請期待！
		</p>
	</main>
</BaseLayout>
