---
import BaseLayout from '../layouts/BaseLayout.astro';
import MembersRoster from '../components/MembersRoster';
import { getAllMembers } from '../data/members';
---

<BaseLayout title="Members | 日本文化研究社">
	<main class="mx-auto max-w-6xl px-6 pt-28 pb-20">
		<h1 class="text-3xl font-bold text-gray-900">Members</h1>
		<p class="mt-2 text-gray-500">歷屆社員</p>

		<div class="mt-8">
			<MembersRoster client:load members={getAllMembers()} />
		</div>
	</main>
</BaseLayout>
