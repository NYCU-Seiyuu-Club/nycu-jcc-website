---
import BaseLayout from '../layouts/BaseLayout.astro';
import { convenientLinks, selfMadeTools } from '../data/links';
---

<BaseLayout title="相關連結 | 日本文化研究社" description="合作社團、相關網站與自製小工具連結。">
	<main class="mx-auto max-w-5xl px-6 pt-28 pb-20">
		<h1 class="text-center text-3xl font-bold text-gray-900">相關連結</h1>
		<div class="mx-auto mt-2 h-1 w-14 rounded-full bg-[#FFA500]"></div>
		<p class="mt-3 text-center text-gray-500">合作社團、相關網站與自製小工具</p>

		<section id="convenient" class="reveal mt-16 scroll-mt-28">
			<h2 class="text-2xl font-bold text-gray-900">便利連結</h2>
			<div class="mt-1 h-1 w-10 rounded-full bg-[#FFA500]"></div>

			<div class="mt-8 space-y-8">
				{
					convenientLinks.map((link) => (
						<a
							href={link.url}
							target="_blank"
							rel="noreferrer"
							class="group flex flex-col overflow-hidden rounded-2xl border border-gray-200 shadow-sm transition-shadow hover:shadow-lg sm:flex-row"
						>
							<div class="sm:w-2/5">
								<img
									src={link.image}
									alt={link.title}
									class="h-56 w-full object-cover transition-transform duration-300 group-hover:scale-105 sm:h-full"
								/>
							</div>
							<div class="flex flex-1 flex-col justify-center p-8">
								<span class="text-xs font-semibold uppercase tracking-widest text-gray-400">
									{link.domain}
								</span>
								<h3 class="mt-2 text-2xl font-bold text-gray-900">{link.title}</h3>
								<p class="mt-3 text-gray-600">{link.description}</p>
								<span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-orange-600">
									前往網站 →
								</span>
							</div>
						</a>
					))
				}
			</div>

			{
				convenientLinks.length === 0 && (
					<p class="mt-12 text-center text-gray-400">目前沒有便利連結。</p>
				)
			}
		</section>

		<section id="tools" class="reveal mt-20 scroll-mt-28">
			<h2 class="text-2xl font-bold text-gray-900">自製小工具</h2>
			<div class="mt-1 h-1 w-10 rounded-full bg-[#FFA500]"></div>

			<div class="mt-8 space-y-8">
				{
					selfMadeTools.map((link) => (
						<a
							href={link.url}
							target="_blank"
							rel="noreferrer"
							class="group flex flex-col overflow-hidden rounded-2xl border border-gray-200 shadow-sm transition-shadow hover:shadow-lg sm:flex-row"
						>
							<div class="sm:w-2/5">
								<img
									src={link.image}
									alt={link.title}
									class="h-56 w-full object-cover transition-transform duration-300 group-hover:scale-105 sm:h-full"
								/>
							</div>
							<div class="flex flex-1 flex-col justify-center p-8">
								<span class="text-xs font-semibold uppercase tracking-widest text-gray-400">
									{link.domain}
								</span>
								<h3 class="mt-2 text-2xl font-bold text-gray-900">{link.title}</h3>
								<p class="mt-3 text-gray-600">{link.description}</p>
								<span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-orange-600">
									前往網站 →
								</span>
							</div>
						</a>
					))
				}
			</div>

			{
				selfMadeTools.length === 0 && (
					<p class="mt-12 text-center text-gray-400">目前沒有自製小工具。</p>
				)
			}
		</section>
	</main>
</BaseLayout>
